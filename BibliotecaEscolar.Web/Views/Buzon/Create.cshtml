@model BibliotecaEscolar.Web.Models.Mensaje

@{
    ViewData["Title"] = "Enviar Mensaje";
}

<h1>Enviar Mensaje</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <div class="mb-3">
                <label asp-for="Asunto"
                       class="form-label">
                </label>

                <input asp-for="Asunto"
                       class="form-control" />

                <span asp-validation-for="Asunto"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Contenido"
                       class="form-label">
                    Mensaje
                </label>

                <textarea asp-for="Contenido"
                          class="form-control"
                          rows="6">
                </textarea>

                <span asp-validation-for="Contenido"
                      class="text-danger">
                </span>
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Enviar
            </button>

            <a asp-action="MisMensajes"
               class="btn btn-secondary">
                Mis Mensajes
            </a>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}