@model IEnumerable<BibliotecaEscolar.Web.Models.Libro>

<h1>Catálogo de Libros</h1>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Libro
</a>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Título</th>
            <th>Autor</th>
            <th>Editorial</th>
            <th>Año</th>
            <th>Existencias</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach(var libro in Model)
        {
            <tr>

                <td>@libro.Titulo</td>
                <td>@libro.Autor</td>
                <td>@libro.Editorial</td>
                <td>@libro.Anio</td>
                <td>@libro.Existencias</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@libro.IdLibro"
                       class="btn btn-info btn-sm">
                        Detalles
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@libro.IdLibro"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@libro.IdLibro"
                       class="btn btn-danger btn-sm">
                        Eliminar
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>