@{
    ViewData["Title"] = "Ayuda";
}

<div class="container mt-4">
    <h2>Centro de Ayuda</h2>
    <hr />

    <div class="card mb-3">
        <div class="card-body">
            <h5>¿Cómo buscar un libro?</h5>
            <p>
                Ingresa al apartado "Libros" y utiliza el buscador para localizar
                títulos, autores o categorías.
            </p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>¿Cómo solicitar un préstamo?</h5>
            <p>
                Accede a la sección "Préstamos", selecciona el libro deseado
                y registra la solicitud.
            </p>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5>¿Olvidaste tu contraseña?</h5>
            <p>
                Utiliza la opción "Recuperar contraseña" disponible en la pantalla
                de inicio de sesión.
            </p>
        </div>
    </div>
</div>