@model BibliotecaEscolar.Web.Models.Usuario

@{
    ViewData["Title"] = "Registro";
}

<h2>Registro de Usuario</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

<form asp-action="Register">

    <div asp-validation-summary="ModelOnly"
         class="text-danger">
    </div>

    <div class="mb-3">
        <label asp-for="Nombre"
               class="form-label"></label>

        <input asp-for="Nombre"
               class="form-control" />

        <span asp-validation-for="Nombre"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Correo"
               class="form-label"></label>

        <input asp-for="Correo"
               class="form-control" />

        <span asp-validation-for="Correo"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Contrasena"
               class="form-label"></label>

        <input asp-for="Contrasena"
               type="password"
               class="form-control" />

        <span asp-validation-for="Contrasena"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Matricula"
               class="form-label"></label>

        <input asp-for="Matricula"
               class="form-control" />

        <span asp-validation-for="Matricula"
              class="text-danger"></span>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Registrarse
    </button>
    
    <div class="mb-3">
        <div class="g-recaptcha"
            data-sitekey="@ViewBag.SiteKey">
        </div>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
