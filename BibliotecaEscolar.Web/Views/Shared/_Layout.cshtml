<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData[index: "Title"] - Biblioteca Escolar</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BibliotecaEscolar.Web.styles.css" asp-append-version="true" />
</head>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const btnTema = document.getElementById("btnTema");

        if (localStorage.getItem("tema") === "oscuro") {
            document.body.classList.add("dark-mode");
            btnTema.innerHTML = "☀️";
        }

        btnTema.addEventListener("click", function () {

            document.body.classList.toggle("dark-mode");

            if (document.body.classList.contains("dark-mode")) {

                localStorage.setItem("tema", "oscuro");
                btnTema.innerHTML = "☀️";

            } else {

                localStorage.setItem("tema", "claro");
                btnTema.innerHTML = "🌙";
            }

        });

    });
</script>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-4">
            <div class="container-fluid">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">Biblioteca Escolar Digital</a>                
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                            asp-controller="Home"
                            asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                            asp-controller="Libros"
                            asp-action="Index">
                                Libros
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                            asp-controller="Account"
                            asp-action="Register">
                                Registros
                            </a>
                        </li>

                        <a class="nav-link"
                            asp-controller="Prestamos"
                            asp-action="Index">
                                Préstamos
                        </a>

                        <li class="nav-item">
                            <a class="nav-link">
                                Ayuda
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link">
                                Contacto
                            </a>
                        </li>

                    </ul>
                    <div class="d-flex align-items-center">
                        <button id="btnTema" class="btn btn-outline-light">
                            🌙
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
